title = \{\{Does saying 'yes' to capital inflows necessarily mean good business? The effect of antimoney laundering regulations in the latin american and the caribbean economies\}\},\
volume = \{26\},\
year = \{2014\}\
\}\
@article\{Heckelman2013,\
abstract = \{We investigate whether the impact of institutions depends not just on their current state but also on how they came to be. In particular, we hypothesize that while economic freedom that emerges spontaneously may be growth promoting, economic freedom that emerges as a result of costly lobbying efforts may be less fruitful. In an extreme case, costly lobbying efforts may even negate the growth-enhancing effect of economic freedom. To the extent that lobbying efforts constitute an opportunity cost of resources diverted away from investment and production, our hypothesis also implies that greater the opportunity cost of lobbying, the more efficient is the institutional environment. Panel data analysis reveals the expected positive relation between economic freedom and growth, and consistent with our hypothesis, the findings indicate that the impact of economic freedom on growth does indeed diminish as lobbying efforts increase. In addition, we find that lobbying is more harmful to growth at greater levels of economic freedom. \{\\textcopyright\} 2013 John Wiley \{\\&\} Sons Ltd.\},\
author = \{Heckelman, Jac C. and Wilson, Bonnie\},\
doi = \{10.1111/ecpo.12016\},\
file = \{:Users/rw23826/Library/Application Support/Mendeley Desktop/Downloaded/Heckelman, Wilson - 2013 - Institutions, lobbying, and economic performance.pdf:pdf\},\
issn = \{09541985\},\
journal = \{Economics and Politics\},\
keywords = \{foreign direct investment\},\
mendeley-tags = \{foreign direct investment\},\
number = \{3\},\
pages = \{360--386\},\
title = \{\{Institutions, lobbying, and economic performance\}\},\
volume = \{25\},\
year = \{2013\}\
\}\
@article\{Ansell2018,\
abstract = \{In recent years, global imbalances have channeled the excess savings of surplus countries toward the real estate markets of deficit countries. By consequence, the deficit countries that attracted lots of foreign capital experienced large run-ups in house prices, whereas most surplus countries that exported capital exhibited flat or slow house price growth. We first use new house price data and a novel instrumental variable design to show the causal relationship between housing prices and capital inflows, particularly through debt bonanzas. We then argue that international capital flows affect the fiscal policy preferences of both voters and political parties by way of their impact on housing prices. Where capital inflows are large and housing prices are rising, we expect voters to respond by demanding both lower taxes and less publicly-provided social insurance because rising house prices allow homeowners to self-insure against income loss. In contrast, declining house prices produce greater demands for social insurance, particularly among those most exposed to housing market risk. We present evidence from two cross-national surveys that supports these claims, as well as a \'93before and after\'94 analysis of the housing crash in Eastern Europe. We also show that the connection between house prices and social policy also manifests itself in government spending outcomes, mediated by partisan control.\},\
author = \{Ansell, Ben W. and Broz, J. Lawrence and Flaherty, Thomas\},\
doi = \{10.1111/ecpo.12111\},\
file = \{:Users/rw23826/Library/Application Support/Mendeley Desktop/Downloaded/Ansell, Broz, Flaherty - 2018 - Global capital markets, housing prices, and partisan fiscal policies.pdf:pdf\},\
issn = \{14680343\},\
journal = \{Economics and Politics\},\
keywords = \{fiscal policy,foreign direct investment,globalization/integration,public finance,redistribution\},\
mendeley-tags = \{foreign direct investment\},\
number = \{3\},\
pages = \{307--339\},\
title = \{\{Global capital markets, housing prices, and partisan fiscal policies\}\},\
volume = \{30\},\
year = \{2018\}\
\}\
