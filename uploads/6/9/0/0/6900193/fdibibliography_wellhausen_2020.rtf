\}\
@article\{Arel-Bundock2017a,\
abstract = \{The international tax system is a complex regime composed of thousands of bilateral tax treaties. These agreements coordinate policies between countries to avoid double taxation and encourage international investment. I argue that by solving this coordination problem on a bilateral basis, states have inadvertently created opportunities for treaty shopping by multinationals. These opportunities, in turn, reduce the potency of fiscal policy, put pressure on governments to change their domestic tax laws, and ultimately constrain state autonomy. This constraint is theoretically distinct from the usual race-to-the-bottom story and it generates different testable implications. I use a motivating case study to show how multinationals leverage the structure of the treaty network to reduce their tax burden. Then, I develop a new measure of treaty-shopping opportunities for firms in 164 countries. Where the proliferation of tax treaties allows multinationals to engage in treaty shopping, states' fiscal autonomy is limited, and governments tend to maintain lower tax rates.\},\
author = \{Arel-Bundock, Vincent\},\
doi = \{10.1017/S0020818317000108\},\
file = \{:Users/rw23826/Library/Application Support/Mendeley Desktop/Downloaded/Arel-Bundock - 2017 - The Unintended Consequences of Bilateralism Treaty Shopping and International Tax Policy(2).pdf:pdf;:Users/rw23826/Library/Application Support/Mendeley Desktop/Downloaded/Arel-Bundock - 2017 - The Unintended Consequences of Bilateralism Treaty Shopping and International Tax Policy.pdf:pdf\},\
