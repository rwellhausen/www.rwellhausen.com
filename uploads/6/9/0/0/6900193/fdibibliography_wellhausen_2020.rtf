issn = \{02636050\},\
month = \{dec\},\
publisher = \{Cambridge University Press\},\
title = \{\{Merging Interests\}\},\
url = \{https://www.cambridge.org/core/product/identifier/9781108657143/type/book\},\
year = \{2020\}\
\}\
