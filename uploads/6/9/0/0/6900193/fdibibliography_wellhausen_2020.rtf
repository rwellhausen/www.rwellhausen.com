keywords = \{Comparative advantage,Industrial fragmentation,Lobbying,Services,Trade agreements\},\
pages = \{261--296\},\
publisher = \{The Review of International Organizations\},\
title = \{\{The service economy: U.S. trade coalitions in an era of deindustrialization\}\},\
year = \{2019\}\
\}\
