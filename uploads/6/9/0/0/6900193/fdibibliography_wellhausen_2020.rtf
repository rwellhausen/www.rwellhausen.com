year = \{2018\}\
\}\
@article\{Escriba-Folch2018,\
abstract = \{Remittances\'97money migrant workers send back home\'97are the second largest source of international financial flows in developing countries. As with other sources of international finance, such as foreign direct investment and foreign aid, worker remittances shape politics in recipient countries. We examine the political consequences of remittances by exploring how they influence antigovernment protest behavior. While recent research argues that remittances have a pernicious effect on politics by contributing to authoritarian stability, we argue the opposite: Remittances increase political protest in nondemocracies by augmenting the resources available to potential political opponents. Using cross-national data on a latent measure of antigovernment political protest, we show that remittances increase protest. To explore the mechanism linking remittances to protest, we turn to individual-level data from eight nondemocracies in Africa to show that remittance receipt increases protest in opposition areas but not in progovernment regions.\},\
author = \{Escrib\{\\`\{a\}\}-Folch, Abel and Meseguer, Covadonga and Wright, Joseph\},\
doi = \{10.1111/ajps.12382\},\
file = \{:Users/rw23826/Library/Application Support/Mendeley Desktop/Downloaded/Escrib\{\\`\{a\}\}-Folch, Meseguer, Wright - 2018 - Remittances and Protest in Dictatorships.pdf:pdf\},\
issn = \{15405907\},\
