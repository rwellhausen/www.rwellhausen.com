@article\{Biglaiser2016,\
abstract = \{This paper seeks to explain the determinants of foreign expropriation in the developing world. We argue that the International Monetary Fund (IMF) helps to reduce the likelihood of nationalization because of the direct leverage the Fund holds over borrowers, especially as expropriation is a blatant violation of international property rights. Using expropriation data from 1961 to 2006, and several different measures for the Fund, we find that countries under IMF agreements are less likely to nationalize foreign firms. We also show that the Fund's influence is greatest when the IMF loan represents a larger share of the borrower country's gross domestic product (GDP) as well as in countries with weaker political institutions. The takeaway is that IMF continues to influence policy choices in the developing world.\},\
author = \{Biglaiser, Glen and Lee, Hoon and Staats, Joseph L.\},\
doi = \{10.1007/s11558-015-9226-8\},\
file = \{:Users/rw23826/Library/Application Support/Mendeley Desktop/Downloaded/Biglaiser, Lee, Staats - 2016 - The effects of the IMF on expropriation of foreign firms.pdf:pdf\},\
issn = \{15597431\},\
