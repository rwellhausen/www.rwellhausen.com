journal = \{International Studies Quarterly\},\
number = \{1\},\
pages = \{106--117\},\
title = \{\{Trade Policy, Economic Interests, and Party Politics in a Developing Country: The Political Economy of CAFTA-DR\}\},\
volume = \{58\},\
year = \{2014\}\
\}\
@article\{Wellhausen2015b,\
abstract = \{We often presume that international financial actors have the same preferences, but this paper asks whether the property rights of foreign direct investors matter to sovereign bondholders. When governments expropriate direct investors, different investors' preferences could align over property rights issues. However, bondholders likely take positive signals if expropriation generates revenue for the state. Using a novel data set (1995-2011), I find that governments that earn revenue from expropriation can enjoy lower long-term spreads on sovereign bonds. Although governments that expropriate lose out on FDI, they can benefit by generating revenue and enjoying rewards in sovereign debt markets. Unpacking investor preferences thus reveals gaps in market-based informal property rights enforcement. When bondholders' and direct investors' preferences conflict, governments gain space to prioritize other goals over the protection of private property.\},\
author = \{Wellhausen, Rachel L.\},\
doi = \{10.1111/isqu.12194\},\
file = \{:Users/rw23826/Library/Application Support/Mendeley Desktop/Downloaded/Wellhausen - 2015 - Bondholders vs. Direct Investors Competing Responses to Expropriation(2).pdf:pdf;:Users/rw23826/Library/Application Support/Mendeley Desktop/Downloaded/Wellhausen - 2015 - Bondholders vs. Direct Investors Competing Responses to Expropriation.pdf:pdf\},\
issn = \{14682478\},\
journal = \{International Studies Quarterly\},\
month = \{mar\},\
