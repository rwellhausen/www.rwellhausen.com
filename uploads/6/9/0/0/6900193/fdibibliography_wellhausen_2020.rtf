keywords = \{Anti-dumping disputes,Dispute settlement,Global value chains,Multinational firms,World Trade Organization\},\
number = \{2\},\
pages = \{239--260\},\
publisher = \{The Review of International Organizations\},\
title = \{\{Global value chains and the political economy of WTO disputes\}\},\
volume = \{14\},\
year = \{2019\}\
\}\
