journal = \{Economics and Politics\},\
number = \{1\},\
pages = \{48--68\},\
title = \{\{Trade and the Recognition of Commercial Lingua Francas: Russian Language Laws in Post-Soviet Countries\}\},\
volume = \{29\},\
year = \{2017\}\
\}\
@article\{Farias2014,\
abstract = \{This study explores the level of compliance and the subsequent economic performance of states in the context of anti-money laundering (AML) regulations. Following Holmstrom and Tirole (1997) and Obstfeld and Rogoff (1998), we examine why countries admit illicit flows of money and the economic costs of these transactions. Analyzing 36 Latin American and Caribbean jurisdictions between 1960 and 2010, we find that poor institutional performance by a jurisdiction (AML ratings, blacklists with non-cooperator countries, and corruption indicators) affects negatively the investment ratio to GDP, the FDI ratio to GDP, and financial development (ratio of credit markets to GDP). These findings are novel in the literature, offering an important contribution to the debate on financial regulatory convergence. \{\\textcopyright\} 2013 John Wiley \{\\&\} Sons Ltd.\},\
author = \{Far\{\\'\{i\}\}as, Mar\{\\'\{i\}\}a Elisa and de Almeida, Monica Arruda\},\
doi = \{10.1111/ecpo.12028\},\
