@article\{Monteiro2015,\
abstract = \{Multinational corporations (MNCs) frequently use their foreign subsidiaries to identify new opportunities to access external knowledge. This article builds on the attention-based view to examine how selective attention - the focus on certain issues or answers at the exclusion of others - works in the global knowledge-sourcing process in MNCs. The results reveal an intriguing paradox: while MNCs may establish foreign subsidiaries far from headquarters to identify diverse, novel knowledge, and overcome local search, headquarters' decision makers tend to favor opportunities that are market proven and simply confirm what the MNC already knows. Subsidiary managers' pre-selling and selling efforts, however, can play a pivotal role in overcoming that bias. This study combines detailed qualitative data with access to a proprietary database on 137 external knowledge-sourcing opportunities in one of the world's largest MNCs in the telecommunications sector.\},\
author = \{Monteiro, L. Felipe\},\
doi = \{10.1057/jibs.2014.72\},\
file = \{:Users/rw23826/Library/Application Support/Mendeley Desktop/Downloaded/Monteiro - 2015 - Selective attention and the initiation of the global knowledge-sourcing process in multinational corporations.pdf:pdf\},\
issn = \{14786990\},\
journal = \{Journal of International Business Studies\},\
keywords = \{attention-based view,headquarters-subsidiary roles and relations,knowledge acquisition and sharing,knowledge sourcing,knowledge transfer and innovation in MNCs/MNEs,knowledge-based view\},\
month = \{jun\},\
number = \{5\},\
pages = \{505--527\},\
publisher = \{Palgrave Macmillan Ltd.\},\
title = \{\{Selective attention and the initiation of the global knowledge-sourcing process in multinational corporations\}\},\
volume = \{46\},\
year = \{2015\}\
\}\
@misc\{Benito2019,\
abstract = \{In a research note in this issue, Strange and Humphrey discuss how a global value chain (GVC) approach serves to usefully move internalization theory towards a better understanding of the increasingly important \'91middle ground' between markets and hierarchies in the contemporary highly globalized international business scene. After a brief recount of their main arguments, we argue that their discussion needs to the extended, as it does not adequately recognize important differences between internalization theory and the GVC approach. Specifically, the approaches differ on the notions of efficiency, opportunism, and level of analysis. We then argue that internalization theory can benefit from the systemic view implied in the GVC approach, and discuss the role of trust as a coordinating mechanism in international business. This leads to a more general discussion of internalization theory and the difficulty of encompassing dynamic considerations such as learning and foreign operation mode combinations and flexibility within value chain interdependencies. We conclude with a research agenda that flows from our discussion.\},\
author = \{Benito, Gabriel R.G. and Petersen, Bent and Welch, Lawrence S.\},\
booktitle = \{Journal of International Business Studies\},\
doi = \{10.1057/s41267-019-00218-8\},\
file = \{:Users/rw23826/Library/Application Support/Mendeley Desktop/Downloaded/Benito, Petersen, Welch - 2019 - The global value chain and internalization theory.pdf:pdf\},\
issn = \{14786990\},\
keywords = \{foreign operation modes,global value chains,internalization theory,multinational corporations\},\
month = \{oct\},\
publisher = \{Palgrave Macmillan Ltd.\},\
title = \{\{The global value chain and internalization theory\}\},\
year = \{2019\}\
\}\
