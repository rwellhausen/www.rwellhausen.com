volume = \{113\},\
year = \{2019\}\
\}\
@article\{Rottgers2014,\
abstract = \{African countries have hardly used the opportunity to implement CDM projects and thereby turn environmental problems into business and development opportunities. This paper finds out why by identifying factors of CDM partnerships. Our gravity model analyzes flows of Certified Emission Reductions (CERs) between host and financier countries. Findings show that foreign direct investments, official development assistance, and trade have a positive influence on project attraction. A distinction between project initiation and CER flow size shows that the specific shortcomings of African countries lie with the initial attraction of investors. This points to an inadequacy in the initial process of project generation. \{\\textcopyright\} 2014 Elsevier Ltd.\},\
author = \{R\{\\"\{o\}\}ttgers, Dirk and Grote, Ulrike\},\
doi = \{10.1016/j.worlddev.2014.05.009\},\
