year = \{2018\}\
\}\
@book\{rajegopal2012portfolio,\
abstract = \{In Portfolio Management , Shan Rajegopal, a leading authority on innovation and project portfolio management, provides an integrated project portfolio management framework which links innovation, investment and implementation. A successful tried and tested method, this blueprint will be a hands-on guide for business executives.\},\
