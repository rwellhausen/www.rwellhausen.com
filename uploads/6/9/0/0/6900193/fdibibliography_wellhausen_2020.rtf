keywords = \{Institutional theory,Legitimacy,Non-market strategy,Political risk,Political ties; natural experiment\},\
month = \{jan\},\
number = \{1\},\
pages = \{68--92\},\
publisher = \{Palgrave Macmillan Ltd.\},\
title = \{\{Uncovering the complex relationships between political risk and MNE firm legitimacy: Insights from Libya\}\},\
